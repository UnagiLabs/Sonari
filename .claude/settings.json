{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'd=$(git rev-parse --show-toplevel 2>/dev/null); [ -n \"$d\" ] && exec bash \"$d/.claude/hooks/format-changed.sh\"; exit 0'",
            "statusMessage": "Biome: format changed file"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "bash -lc 'd=$(git rev-parse --show-toplevel 2>/dev/null); [ -n \"$d\" ] && exec bash \"$d/.claude/hooks/precommit-quality-gate.sh\"; exit 0'",
            "statusMessage": "Sonari pre-commit quality gate",
            "timeout": 600
          }
        ]
      }
    ]
  }
}
