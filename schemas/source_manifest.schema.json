{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sonari.example/schemas/source_manifest.schema.json",
  "title": "Sonari Source Manifest",
  "$comment": "source_set_hash = SHA-256(canonical_source_manifest_json_bytes). Canonical JSON must emit keys in this schema order, with no whitespace, no trailing newline, and UTF-8 bytes. Hex hashes must be lowercase 0x plus 64 hex characters. sources must be sorted by name, event_id, product, product_version, updated_at_ms ascending.",
  "type": "object",
  "additionalProperties": false,
  "required": ["sources", "cells_generation_method", "oracle_version"],
  "properties": {
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "event_id",
          "product",
          "product_version",
          "map_status",
          "updated_at_ms",
          "url_hash"
        ],
        "properties": {
          "name": {
            "type": "string",
            "enum": ["USGS"]
          },
          "event_id": {
            "type": "string",
            "minLength": 1
          },
          "product": {
            "type": "string",
            "minLength": 1
          },
          "product_version": {
            "type": "string",
            "minLength": 1
          },
          "map_status": {
            "type": "string",
            "enum": ["REVIEWED", "RELEASED", "CANCELLED"]
          },
          "updated_at_ms": {
            "type": "integer",
            "minimum": 0
          },
          "url_hash": {
            "type": "string",
            "pattern": "^0x[0-9a-f]{64}$"
          }
        }
      }
    },
    "cells_generation_method": {
      "type": "string",
      "enum": [
        "shakemap_gridxml_h3_grid_point_p90_v1",
        "shakemap_hdf_h3_area_weighted_p90_v1",
        "shakemap_gridxml_h3_center_bilinear_v1"
      ]
    },
    "oracle_version": {
      "type": "integer",
      "minimum": 1
    }
  }
}
