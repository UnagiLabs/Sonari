{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sonari.example/schemas/affected_cells.schema.json",
  "title": "Sonari Affected Cells",
  "$comment": "affected_cells_data_hash = SHA-256(canonical_affected_cells_json_bytes). Canonical JSON must emit keys in this schema order, with no whitespace, no trailing newline, and UTF-8 bytes. event_uid and all hex hashes must be lowercase 0x plus 64 hex characters. affected_cells must be sorted by numeric h3_index ascending, duplicate h3_index values are invalid, and h3_index must be a decimal string without leading zero unless it is exactly \"0\".",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_uid",
    "event_revision",
    "oracle_version",
    "geo_resolution",
    "cells_generation_method",
    "cell_metric",
    "cell_aggregation",
    "intensity_scale",
    "affected_cells"
  ],
  "properties": {
    "event_uid": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "event_revision": {
      "type": "integer",
      "minimum": 1
    },
    "oracle_version": {
      "type": "integer",
      "minimum": 1
    },
    "geo_resolution": {
      "type": "integer",
      "const": 7
    },
    "cells_generation_method": {
      "type": "string",
      "enum": [
        "shakemap_gridxml_h3_grid_point_p90_v1",
        "shakemap_hdf_h3_area_weighted_p90_v1"
      ]
    },
    "cell_metric": {
      "type": "string",
      "enum": ["USGS_MMI"]
    },
    "cell_aggregation": {
      "type": "string",
      "enum": ["GRID_POINT_P90"]
    },
    "intensity_scale": {
      "type": "string",
      "enum": ["MMI_X100"]
    },
    "affected_cells": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["h3_index", "intensity_value", "cell_band"],
        "properties": {
          "h3_index": {
            "type": "string",
            "pattern": "^(0|[1-9][0-9]*)$"
          },
          "intensity_value": {
            "type": "integer",
            "minimum": 0
          },
          "cell_band": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3
          }
        }
      }
    }
  }
}
