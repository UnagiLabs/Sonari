{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sonari.example/schemas/affected_cells.schema.json",
  "title": "Sonari Affected Cells",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_uid",
    "event_revision",
    "oracle_version",
    "geo_resolution",
    "cells_generation_method",
    "cell_metric",
    "cell_aggregation",
    "intensity_scale",
    "affected_cells"
  ],
  "properties": {
    "event_uid": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{64}$"
    },
    "event_revision": {
      "type": "integer",
      "minimum": 1
    },
    "oracle_version": {
      "type": "integer",
      "minimum": 1
    },
    "geo_resolution": {
      "type": "integer",
      "const": 7
    },
    "cells_generation_method": {
      "type": "string",
      "enum": [
        "shakemap_gridxml_h3_grid_point_p90_v1",
        "shakemap_hdf_h3_area_weighted_p90_v1",
        "jma_250m_h3_p90_v1"
      ]
    },
    "cell_metric": {
      "type": "string",
      "enum": ["USGS_MMI", "JMA_SHINDO"]
    },
    "cell_aggregation": {
      "type": "string",
      "enum": ["GRID_POINT_P90"]
    },
    "intensity_scale": {
      "type": "string",
      "enum": ["MMI_X100", "JMA_SHINDO_X10"]
    },
    "affected_cells": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["h3_index", "intensity_value", "cell_band"],
        "properties": {
          "h3_index": {
            "type": "string",
            "pattern": "^[0-9]+$"
          },
          "intensity_value": {
            "type": "integer",
            "minimum": 0
          },
          "cell_band": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3
          }
        }
      }
    }
  },
  "$comment": "affected_cells_data_hash is the hash of this canonical JSON file after deterministic serialization. affected_cells must be sorted by numeric h3_index ascending before hashing and Merkle root generation."
}
