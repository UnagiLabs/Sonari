{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sonari.example/schemas/census_tee_input.schema.json",
  "title": "Sonari Census TEE Input",
  "$comment": "MVP input for the census TEE. BCS output field order is defined separately in schemas/census_result.bcs.md.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_uid",
    "event_revision",
    "occurred_at_ms",
    "affected_cells_root",
    "issued_at_ms",
    "campaign_id",
    "disaster_event_id",
    "membership_registry_id",
    "census_checkpoint",
    "affected_cells",
    "home_cell_events",
    "active_lineages",
    "authenticated_event_proof"
  ],
  "properties": {
    "event_uid": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "event_revision": {
      "type": "integer",
      "minimum": 1
    },
    "occurred_at_ms": {
      "type": "integer",
      "minimum": 0
    },
    "affected_cells_root": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "issued_at_ms": {
      "type": "integer",
      "minimum": 0
    },
    "campaign_id": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "disaster_event_id": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "membership_registry_id": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "census_checkpoint": {
      "type": "integer",
      "minimum": 0
    },
    "affected_cells": {
      "type": "object"
    },
    "home_cell_events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["lineage", "home_cell", "registered_at_ms"],
        "properties": {
          "lineage": {
            "type": "string",
            "pattern": "^0x[0-9a-f]{64}$"
          },
          "home_cell": {
            "type": "string",
            "pattern": "^(0|[1-9][0-9]*)$"
          },
          "registered_at_ms": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "active_lineages": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^0x[0-9a-f]{64}$"
      }
    },
    "authenticated_event_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol",
        "stream_id",
        "event_stream_head_object_id",
        "start_checkpoint",
        "end_checkpoint",
        "highest_indexed_checkpoint",
        "validator_committee_bcs",
        "checkpoint_summary_bcs",
        "checkpoint_signature_bcs",
        "event_stream_head",
        "ocs_proof",
        "events"
      ],
      "properties": {
        "protocol": {
          "const": "sui-authenticated-events-v1"
        },
        "stream_id": {
          "type": "string",
          "pattern": "^0x[0-9a-f]{64}$"
        },
        "event_stream_head_object_id": {
          "type": "string",
          "pattern": "^0x[0-9a-f]{64}$"
        },
        "start_checkpoint": {
          "type": "integer",
          "minimum": 0
        },
        "end_checkpoint": {
          "type": "integer",
          "minimum": 0
        },
        "highest_indexed_checkpoint": {
          "type": "integer",
          "minimum": 0
        },
        "validator_committee_bcs": {
          "type": "string",
          "contentEncoding": "base64"
        },
        "checkpoint_summary_bcs": {
          "type": "string",
          "contentEncoding": "base64"
        },
        "checkpoint_signature_bcs": {
          "type": "string",
          "contentEncoding": "base64"
        },
        "event_stream_head": {
          "type": "object",
          "additionalProperties": false,
          "required": ["object_id", "version", "digest", "object_bcs"],
          "properties": {
            "object_id": {
              "type": "string",
              "pattern": "^0x[0-9a-f]{64}$"
            },
            "version": {
              "type": "string",
              "pattern": "^(0|[1-9][0-9]*)$"
            },
            "digest": {
              "type": "string",
              "pattern": "^[1-9A-HJ-NP-Za-km-z]{32,44}$"
            },
            "object_bcs": {
              "type": "string",
              "contentEncoding": "base64"
            }
          }
        },
        "ocs_proof": {
          "type": "object",
          "additionalProperties": false,
          "required": ["leaf_index", "tree_root", "merkle_proof"],
          "properties": {
            "leaf_index": {
              "type": "integer",
              "minimum": 0
            },
            "tree_root": {
              "type": "string",
              "pattern": "^[1-9A-HJ-NP-Za-km-z]{32,44}$"
            },
            "merkle_proof": {
              "type": "array",
              "items": {
                "type": "string",
                "contentEncoding": "base64"
              }
            }
          }
        },
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "checkpoint",
              "transaction_index",
              "event_index",
              "type",
              "event_bcs"
            ],
            "properties": {
              "checkpoint": {
                "type": "integer",
                "minimum": 0
              },
              "transaction_index": {
                "type": "integer",
                "minimum": 0
              },
              "event_index": {
                "type": "integer",
                "minimum": 0
              },
              "type": {
                "type": "string",
                "minLength": 1
              },
              "event_bcs": {
                "type": "string",
                "contentEncoding": "base64"
              }
            }
          }
        }
      }
    }
  }
}
