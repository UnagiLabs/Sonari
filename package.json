{
    "name": "sonari",
    "version": "0.1.0",
    "private": true,
    "packageManager": "pnpm@10.27.0",
    "type": "module",
    "scripts": {
        "format": "pnpm format:ts && pnpm format:rust",
        "format:ts": "biome check --write .",
        "format:rust": "cargo fmt --all",
        "check": "pnpm check:ts && pnpm check:rust",
        "check:move": "sui move build -p contracts --force --lint --warnings-are-errors && sui move test -p contracts",
        "check:ts": "biome check . && pnpm typecheck",
        "check:rust": "cargo fmt --all --check && cargo clippy --workspace --all-targets -- -D warnings",
        "lint": "pnpm check",
        "typecheck": "pnpm typecheck:packages && pnpm typecheck:scripts",
        "typecheck:packages": "tsc -b --noEmit",
        "typecheck:scripts": "tsc -p scripts/tsconfig.json --noEmit",
        "test": "pnpm -r test && pnpm test:local-e2e",
        "test:local-e2e": "vitest run --dir scripts",
        "build:aws-sonari-verifier-runner-lambda": "tsx scripts/build_aws_sonari_verifier_runner_lambda.ts",
        "build:aws-earthquake-tee-artifact": "tsx scripts/build_aws_earthquake_tee_artifact.ts",
        "build:aws-earthquake-eif": "tsx scripts/build_aws_earthquake_eif.ts",
        "build:aws-membership-identity-tee-artifact": "tsx scripts/build_aws_membership_identity_tee_artifact.ts",
        "build:aws-membership-identity-eif": "tsx scripts/build_aws_membership_identity_eif.ts",
        "aws:preflight": "tsx scripts/aws/preflight.ts",
        "aws:inventory": "tsx scripts/aws/inventory.ts",
        "aws:check-idle": "tsx scripts/aws/check-idle.ts",
        "aws:verify:earthquake-wrapper": "tsx scripts/aws/verify-earthquake-wrapper.ts",
        "aws:verify:source-archiver": "tsx scripts/aws/verify-source-archiver.ts",
        "aws:smoke:earthquake-manual": "tsx scripts/aws/smoke-earthquake-manual.ts",
        "aws:post-deploy-guardrails": "tsx scripts/aws/post-deploy-guardrails.ts",
        "test:relayer": "pnpm --filter @sonari/earthquake-relayer test",
        "relayer": "pnpm --filter @sonari/earthquake-relayer cli",
        "oracle:sidecar:local": "tsx scripts/nautilus_sidecar.ts",
        "oracle:doctor": "tsx scripts/oracle_doctor.ts",
        "oracle:e2e:local": "tsx scripts/nautilus_local_e2e.ts",
        "oracle:e2e:fake-binding": "tsx scripts/nautilus_fake_binding_e2e.ts",
        "oracle:e2e:live": "tsx scripts/nautilus_live_e2e.ts",
        "identity:smoke": "tsx scripts/membership_identity_smoke.ts",
        "identity:testnet-fixture": "tsx scripts/membership_identity_testnet_fixture.ts",
        "identity:sidecar:local": "tsx scripts/membership_identity_sidecar.ts",
        "identity:move-handoff": "tsx scripts/membership_identity_move_handoff.ts",
        "identity:live-gate": "tsx scripts/membership_identity_live_gate.ts",
        "test:oracle": "pnpm --filter './nautilus/verifiers/earthquake/**' test && cargo test -p tee",
        "test:identity": "cargo test -p membership-tee"
    },
    "devDependencies": {
        "@aws-sdk/client-dynamodb": "^3.948.0",
        "@biomejs/biome": "^2.4.15",
        "@sonari/verifier-contracts": "workspace:*",
        "@types/node": "^24.10.2",
        "@types/yazl": "^3.3.1",
        "esbuild": "^0.28.0",
        "tsx": "^4.22.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.15",
        "yazl": "^3.3.1"
    }
}
