{
    "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
    "root": true,
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "includes": [
            "package.json",
            "dapp/package.json",
            "dapp/next.config.ts",
            "dapp/tsconfig.json",
            "dapp/app/**/*.tsx",
            "tsconfig.json",
            "tsconfig.scripts.json",
            "tsconfig.base.json",
            "vitest.config.ts",
            "biome.json",
            "scripts/**/*.ts",
            "nautilus/verifiers/common/contracts/package.json",
            "nautilus/verifiers/common/contracts/tsconfig.json",
            "nautilus/verifiers/common/contracts/src/**/*.ts",
            "nautilus/verifiers/earthquake/shared/package.json",
            "nautilus/verifiers/earthquake/shared/tsconfig.json",
            "nautilus/verifiers/earthquake/shared/src/**/*.ts",
            "nautilus/verifiers/earthquake/watcher/package.json",
            "nautilus/verifiers/earthquake/watcher/tsconfig.json",
            "nautilus/verifiers/earthquake/watcher/src/**/*.ts",
            "nautilus/verifiers/earthquake/relayer/package.json",
            "nautilus/verifiers/earthquake/relayer/tsconfig.json",
            "nautilus/verifiers/earthquake/relayer/src/**/*.ts",
            "nautilus/verifiers/membership/shared/package.json",
            "nautilus/verifiers/membership/shared/tsconfig.json",
            "nautilus/verifiers/membership/shared/src/**/*.ts",
            "nautilus/verifiers/membership/runner/package.json",
            "nautilus/verifiers/membership/runner/tsconfig.json",
            "nautilus/verifiers/membership/runner/src/**/*.ts",
            "nautilus/verifiers/membership/runner/test/**/*.ts"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineEnding": "lf",
        "lineWidth": 100
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double",
            "semicolons": "always",
            "trailingCommas": "all"
        }
    },
    "json": {
        "formatter": {
            "trailingCommas": "none"
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    }
}
