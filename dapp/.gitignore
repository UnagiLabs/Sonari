# Dependencies
node_modules/

# Next.js generated output
.next/
out/
next-env.d.ts

# OpenNext / Cloudflare generated output
# .open-next/ はビルド成果物。cloudflare-env.d.ts は cf-typegen の生成物で commit しない
# （CI が deploy 前に再生成する）。.wrangler/ は wrangler のローカルキャッシュ。
.open-next/
.wrangler/
cloudflare-env.d.ts

# Local environment files
.env*.local

# Local Worker secrets（wrangler dev / opennext preview が読む）。
# 値入りはコミットしない。サンプルの .dev.vars.example だけは追跡する。
.dev.vars
.dev.vars.*
!.dev.vars.example

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Hosting/tool caches
.vercel/
