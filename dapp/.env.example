# dapp 環境変数のサンプル。
#
# このファイルをコピーして dapp/.env.local を作り、値を埋めてください。
#   cp dapp/.env.example dapp/.env.local
#
# NEXT_PUBLIC_* はビルド時にクライアント（ブラウザ側）へ展開される公開値です。
# 秘密情報（秘密鍵・ニーモニック・サーバー専用シークレット）は入れないでください。
# 値を変えたら dev サーバーを再起動してください。
#
# ------------------------------------------------------------
# 本番デプロイでの「出所」（= どこで一元管理するか）
# ------------------------------------------------------------
# 本番（Cloudflare Workers / sonari.help）の値は、ローカルの .env.local ではなく GitHub 側で
# 管理し、Actions（.github/workflows/dapp-deploy.yml）が build 時に焼き込みます。各キーの出所は
# 下の各項目に [出所: ...] で明記しています。種類は次の 4 つです。
#
#   [repo-level]   GitHub repo-level Variables（SONARI_*）。dapp / Cloudflare worker / AWS runner で
#                  共有する単一情報源。1 箇所更新すれば全デプロイ先へ反映される。
#   [env-level]    GitHub Environment（cloudflare-dapp-worker）の Variables。dapp 固有の値。
#   [toml 自動導出] next.config.ts が contracts/Published.toml の published-at から build 時に注入。
#                  env に手書きしない（再 publish のたび toml が自動更新される）。
#   [CF secret]    Cloudflare Worker runtime secret。GitHub Environment Secret から workflow で
#                  同期するものと、Cloudflare 側で手動登録するものがある。
#
# ローカル開発では下の値を .env.local に入れれば動きます（.env.local は git 管理外）。
#
# ------------------------------------------------------------
# Cloudflare（OpenNext）にデプロイするときの変数の扱い
# ------------------------------------------------------------
# このファイルの NEXT_PUBLIC_* は「ビルド時」に値が焼き込まれます。
# つまり `opennextjs-cloudflare build`（CI の deploy 直前）を実行する環境に値が必要です。
# Cloudflare dashboard の runtime 変数に後から入れても、ブラウザ向けの値は変わりません。
#
# サーバー専用シークレット（WORLD_ID_RP_SIGNING_KEY / ENOKI_PRIVATE_API_KEY）は「ランタイム」に読まれます。
# ローカルは dapp/.dev.vars（dapp/.dev.vars.example を参照）を使います。
# WORLD_ID_RP_SIGNING_KEY の本番値は次で Cloudflare 側に登録します。
#   wrangler secret put WORLD_ID_RP_SIGNING_KEY --name sonari-dapp
# ENOKI_PRIVATE_API_KEY の本番値は cloudflare-dapp-worker の GitHub Environment Secret を
# dapp deploy workflow が Cloudflare Worker runtime secret へ同期します。
# このファイル（.env.example / .env.local）には署名鍵や private API key を書きません。

# ============================================================
# Sui ウォレット接続 / ネットワーク
# ============================================================

# 接続先ネットワーク。server route は SONARI_SUI_NETWORK を読み、
# browser bundle は同じ値を NEXT_PUBLIC_SUI_NETWORK として共有します。
# 設定できる値: testnet | localnet
# 未設定や不正値（例: mainnet）は安全側で testnet に丸めます。
# gRPC エンドポイントはこの値に応じてコード側でハードコード分岐します（URL は env に出しません）。
# Enoki / zkLogin もこの値を共有し、明示的に testnet の時だけ有効になります。
# [出所: repo-level] SONARI_SUI_NETWORK（AWS の RELAYER_NETWORK / SourceArchiverSuiNetwork と同源）
SONARI_SUI_NETWORK=testnet
NEXT_PUBLIC_SUI_NETWORK=testnet

# ============================================================
# Enoki / Google zkLogin（testnet）
# ============================================================

# Enoki Portal で作成した testnet app の public API key。
# ブラウザから使う公開値です。sponsored transaction 用の private API key は入れません。
# [出所: env-level] cloudflare-dapp-worker の NEXT_PUBLIC_ENOKI_API_KEY（dapp 固有）
NEXT_PUBLIC_ENOKI_API_KEY=

# Google Cloud Console で作成した OAuth Client ID。
# Enoki Portal の Google provider 設定にも同じ値を登録します。
# Google OAuth の Authorized redirect URIs は http://localhost:3000/ と
# https://sonari.help/ に固定し、https://sonari.help/?next=/register のような
# query 付き URI は登録しません。next は app 内部で一時保存します。
# [出所: env-level] cloudflare-dapp-worker の NEXT_PUBLIC_ENOKI_GOOGLE_CLIENT_ID（dapp 固有）
NEXT_PUBLIC_ENOKI_GOOGLE_CLIENT_ID=

# ============================================================
# Google Maps（住所検索・地図表示）
# ============================================================

# Maps JavaScript API と Places API (New) を有効化した API キー。
# 空のままだと地図も住所検索も表示されず、residence ステップで居住セルを選べない（手入力欄は提供しない）。
# 居住セルの選択にはこのキーが必須。
# [出所: env-level] cloudflare-dapp-worker の NEXT_PUBLIC_GOOGLE_MAPS_API_KEY（dapp 固有）
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ============================================================
# residence-proof-worker（居住セルの陸/海判定）
# ============================================================

# residence-proof-worker のベース URL（/api/... は付けない）。
# [出所: repo-level] SONARI_RESIDENCE_PROOF_WORKER_URL
NEXT_PUBLIC_SONARI_RESIDENCE_PROOF_WORKER_URL=

# ============================================================
# claim（受け取り）の eligibility 確認（任意）
# ============================================================

# affected-cells proof を取得する worker のベース URL。
# 空なら未設定として扱い、claim の eligibility チェックは進みません。
# [出所: repo-level] SONARI_AFFECTED_PROOF_WORKER_URL（AWS の AffectedProofRegistrarUrl と同源）
NEXT_PUBLIC_SONARI_AFFECTED_PROOF_WORKER_URL=

# affected-area map tile artifact の公開 base URL。
# 専用公開 R2 bucket または R2 に接続した CDN/custom domain を指定します。
# 空なら本番 claim 地図は表示用 artifact なしとして扱い、demo は local public asset に fallback します。
# [出所: repo-level] SONARI_AFFECTED_AREA_BASE_URL
NEXT_PUBLIC_SONARI_AFFECTED_AREA_BASE_URL=

# ============================================================
# register/identity（会員登録・本人確認の提出先）（任意）
# ============================================================

# identity の提出先 URL（AWS stack output `SubmitVerificationFunctionUrlOutput` の値）。
# [出所: repo-level] SONARI_IDENTITY_SUBMIT_URL
NEXT_PUBLIC_SONARI_IDENTITY_SUBMIT_URL=

# identity registry のオブジェクト ID。
# [出所: repo-level] SONARI_IDENTITY_REGISTRY_ID（AWS の SonariIdentityRegistryId と同源）
NEXT_PUBLIC_SONARI_IDENTITY_REGISTRY_ID=

# ============================================================
# register/membership（Membership SBT 発行）
# ============================================================

# membership 発行で使う public object ID。production は GitHub repo-level Variables
#（SONARI_*）を GitHub Actions が NEXT_PUBLIC_* として dapp build に注入します。
# [出所: repo-level] SONARI_IDENTITY_PAUSE_STATE_ID
NEXT_PUBLIC_SONARI_IDENTITY_PAUSE_STATE_ID=
# [出所: repo-level] SONARI_MEMBERSHIP_REGISTRY_ID
NEXT_PUBLIC_SONARI_MEMBERSHIP_REGISTRY_ID=
# [出所: repo-level] SONARI_ALLOWED_RESIDENCE_CELL_REGISTRY_ID
NEXT_PUBLIC_SONARI_ALLOWED_RESIDENCE_CELL_REGISTRY_ID=

# membership コントラクトの package ID。
# World ID 登録時に接続中ウォレットが持つ MembershipPass をオンチェーン照会して
# membership_id を自動取得するために使います（`<package_id>::membership::MembershipPass`
# の型フィルタ組み立てに利用）。
#
# 通常は設定不要です。
# [出所: toml 自動導出] testnet は next.config が contracts/Published.toml の published-at を
# ビルド時に読み取り、この変数へ自動注入します（正典＝Published.toml の単一管理）。
# localnet 等で Published.toml に該当エントリが無いときだけ override として値を設定してください
# （env に値があれば Published.toml より優先されます）。空かつ Published.toml にも無い場合は
# 照会できず、World ID 承認ボタンは無効のままになります。
NEXT_PUBLIC_SONARI_MEMBERSHIP_PACKAGE_ID=

# ============================================================
# World ID（本人確認・IDKit）（任意）
# ============================================================
#
# /register/identity の「Verify with World ID」ボタンが使う設定です。
# Developer Portal（https://developer.world.org）でアプリ / RP を作って値を控えます。
#
# 公開してよい値（NEXT_PUBLIC_）とサーバー専用の秘密値を必ず分けてください。
# 署名鍵を NEXT_PUBLIC_ に置くと、ブラウザのバンドルに混入して漏れます。絶対に避けてください。

# --- 公開値（ブラウザに展開されてよい）---

# World ID app ID（client request に渡す）。例: app_1234567890abcdef0
# dapp フロントの IDKit 専用（verifier 側は rp_id で検証するため app_id は共有しない）。
# [出所: env-level] cloudflare-dapp-worker の NEXT_PUBLIC_WORLD_ID_APP_ID（dapp 固有）
NEXT_PUBLIC_WORLD_ID_APP_ID=

# World ID RP ID（proof request の検証に使う）。例: rp_1234567890abcdef0
# [出所: repo-level] SONARI_WORLD_ID_RP_ID（runner の real mode 移行後はここを共有する）
NEXT_PUBLIC_WORLD_ID_RP_ID=

# 接続環境。設定できる値: staging | production
# "staging" のときだけ staging、それ以外は production として扱います。
# [出所: repo-level] SONARI_WORLD_ID_ENVIRONMENT
NEXT_PUBLIC_WORLD_ID_ENVIRONMENT=staging

# --- サーバー専用の秘密値（NEXT_PUBLIC_ を付けない。ブラウザへ出さない）---

# RP 署名鍵。/api/world-id/rp-signature の signRequest だけが使う秘密鍵です。
# これは server 側でのみ読み込まれ、応答・ログ・ブラウザには出しません。
# Developer Portal で発行した signing key（hex）を入れます。
# [出所: CF secret] `wrangler secret put WORLD_ID_RP_SIGNING_KEY --name sonari-dapp`（CI に置かない）
WORLD_ID_RP_SIGNING_KEY=
